# Database
DATABASE_URL=postgresql://ncii_user:ncii_password@postgres:5432/ncii_shield

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# API
NEXT_PUBLIC_API_URL=http://127.0.0.1:8001
APP_PUBLIC_URL=http://127.0.0.1:3001
BACKEND_PUBLIC_URL=http://127.0.0.1:8001
NEXT_PUBLIC_APP_VERSION=community-white-label

# Security
SECRET_KEY=change-this-to-a-secure-random-key
JWT_SECRET_KEY=change-this-to-another-secure-key

# Search API Keys
BING_API_KEY=your-bing-api-key-here
SERPAPI_KEY=your-serpapi-key-here
SERPER_API_KEY=your-serper-api-key-here

# Email sending
RESEND_API_KEY=
RESEND_FROM_EMAIL=NCII Shield <noreply@example.com>
NOTICE_CONTACT_EMAIL=
NOTICE_WEBSITE=https://your-domain.example

# Notice signature
NOTICE_SENDER_NAME=NCII Shield Takedown Team
NOTICE_SENDER_TITLE=Authorized Abuse Reporting Contact
NOTICE_ORGANIZATION=NCII Shield
NOTICE_CLIENT_NAME=the client

# Scraping configuration
PROXY_URL=
SCRAPE_TIMEOUT_SECONDS=30
SCRAPE_RATE_LIMIT_PER_DOMAIN=10
PLAYWRIGHT_HEADLESS=true
THUMBNAIL_TTL_SECONDS=3600
MATCH_PHASH_THRESHOLD=10
MATCH_DHASH_THRESHOLD=8
MATCH_FACE_SIMILARITY_THRESHOLD=0.85
