# Database
DATABASE_URL=postgresql://ncii_user:ncii_password@postgres:5432/ncii_shield

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# API
NEXT_PUBLIC_API_URL=http://127.0.0.1:8001
APP_PUBLIC_URL=http://127.0.0.1:3001
BACKEND_PUBLIC_URL=http://127.0.0.1:8001
NEXT_PUBLIC_APP_VERSION=community

# Security
SECRET_KEY=change-this-to-a-secure-random-key
JWT_SECRET_KEY=change-this-to-another-secure-key

# Search API Keys
BING_API_KEY=
SERPAPI_KEY=
SERPER_API_KEY=

# Email sending
RESEND_API_KEY=
RESEND_FROM_EMAIL=
NOTICE_CONTACT_EMAIL=
NOTICE_WEBSITE=

# Scraping configuration
PROXY_URL=
SCRAPE_TIMEOUT_SECONDS=30
SCRAPE_RATE_LIMIT_PER_DOMAIN=10
PLAYWRIGHT_HEADLESS=true
THUMBNAIL_TTL_SECONDS=3600
MATCH_PHASH_THRESHOLD=10
MATCH_DHASH_THRESHOLD=8
MATCH_FACE_SIMILARITY_THRESHOLD=0.85
